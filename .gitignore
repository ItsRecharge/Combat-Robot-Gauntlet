# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
dist/
*.spec.bak

# PyInstaller work dir (keep build/gauntlet.spec tracked)
build/pyi-work/
build/*.log

# venv
.venv/
venv/

# PyInstaller
*.exe
gauntlet.build/

# OS / editor
.vscode/
.idea/
*.log

# Test / output artifacts
.pytest_cache/
out/
*.png
!data/**/*.png
# README screenshots — keep despite the *.png ignore above
!docs/img/*.png
# App icon (PNG) — bundled by the PyInstaller spec + AppImage; must be tracked
!build/*.png
